{
  "mcpServers": {
    "claude-code-explorer": {
      "command": "node",
      "args": ["mcp-server/dist/src/index.js"],
      "env": {
        "CLAUDE_CODE_SRC_ROOT": "./src"
      }
    },
    "duckduckgo": {
      "command": "npx",
      "args": ["-y", "duckduckgo-mcp-server"]
    },
    "browser": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp"]
    }
  }
}
