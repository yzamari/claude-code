{
  "uid": "claude-code-conversations",
  "title": "Claude Code — Conversations",
  "tags": ["claude-code"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Sessions Created Today",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(conversations_created_total{app=\"claude-code-server\"}[24h])",
          "legendFormat": "sessions"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 2,
      "title": "Messages Sent Today",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(messages_sent_total{app=\"claude-code-server\"}[24h])",
          "legendFormat": "messages"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 3,
      "title": "Tool Executions Today",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(tool_executions_total{app=\"claude-code-server\"}[24h])",
          "legendFormat": "tools"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "title": "Streaming Duration (p50/p95)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(streaming_duration_seconds_bucket{app=\"claude-code-server\"}[5m])) by (le))",
          "legendFormat": "p95"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "title": "Sessions Created / hr",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(conversations_created_total{app=\"claude-code-server\"}[1h])",
          "legendFormat": "sessions/hr"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Messages by Role",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(messages_sent_total{app=\"claude-code-server\"}[5m])) by (role)",
          "legendFormat": "{{role}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "mps" } }
    },
    {
      "id": 7,
      "title": "Tool Executions by Tool",
      "type": "barchart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "topk(10, increase(tool_executions_total{app=\"claude-code-server\"}[24h]))",
          "legendFormat": "{{tool}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 8,
      "title": "Tool Error Rate",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(tool_executions_total{app=\"claude-code-server\",status=\"error\"}[5m])) by (tool) / sum(rate(tool_executions_total{app=\"claude-code-server\"}[5m])) by (tool) * 100",
          "legendFormat": "{{tool}} error %"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent" } }
    }
  ]
}
