{
  "uid": "claude-code-costs",
  "title": "Claude Code — Token Usage & Costs",
  "tags": ["claude-code"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "5m",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Total Input Tokens Today",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(tokens_used_total{app=\"claude-code-server\",type=\"input\"}[24h])",
          "legendFormat": "input tokens"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 2,
      "title": "Total Output Tokens Today",
      "type": "stat",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "increase(tokens_used_total{app=\"claude-code-server\",type=\"output\"}[24h])",
          "legendFormat": "output tokens"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short", "decimals": 0 } }
    },
    {
      "id": 3,
      "title": "Token Rate (input)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(tokens_used_total{app=\"claude-code-server\",type=\"input\"}[5m]))",
          "legendFormat": "tokens/s"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 4,
      "title": "Token Rate (output)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(tokens_used_total{app=\"claude-code-server\",type=\"output\"}[5m]))",
          "legendFormat": "tokens/s"
        }
      ],
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "title": "Token Usage Over Time by Model",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 24, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(tokens_used_total{app=\"claude-code-server\"}[1h])) by (model, type)",
          "legendFormat": "{{model}} {{type}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 6,
      "title": "Input Tokens by Model (7d)",
      "type": "piechart",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(tokens_used_total{app=\"claude-code-server\",type=\"input\"}[7d])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 7,
      "title": "Output Tokens by Model (7d)",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(increase(tokens_used_total{app=\"claude-code-server\",type=\"output\"}[7d])) by (model)",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    }
  ]
}
