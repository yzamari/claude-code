{
  "name": "claude-code-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3000",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:unit": "vitest run --project unit",
    "test:components": "vitest run --project components",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:visual": "playwright test --update-snapshots",
    "test:ci": "vitest run --coverage && playwright test",
    "dev:web": "tsx dev-server.ts",
    "build:web": "vite build --config vite.config.ts",
    "preview:web": "vite preview --config vite.config.ts --port 4001"
  },
